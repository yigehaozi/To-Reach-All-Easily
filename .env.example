# Upstream API used by the local Vite proxy and server.mjs.
UPSTREAM_API_ORIGIN=https://yisi.yun

# Optional. Set this only if your upstream API requires an x-api-key header.
UPSTREAM_API_KEY=

# Public API base shown in the documentation page.
VITE_PUBLIC_API_BASE=https://yisi.yun

# Optional. Leave empty to use same-origin /api/* in the browser.
VITE_API_BASE=

# Optional production server settings.
HOST=127.0.0.1
PORT=3002

# Optional share-result storage settings.
ONEFOUR_SHARE_TTL_SECONDS=7200
ONEFOUR_SHARE_STORAGE_DIR=.onefour-share-data
